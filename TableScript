		readyPlayers[tableFolder] = {}

		eventHandler.OnServerEvent:Connect(function(player, arg, sentTable)
			if sentTable ~= tableFolder then return end
			print("something sent")
			if arg ~= "Ready" then
				if arg == "Unready" then
					print("Unready")
					local char = player.Character
					if char then
						local humanoid = char:FindFirstChild("Humanoid")
						if humanoid then
							humanoid.WalkSpeed = 16
							humanoid.JumpHeight = 7.2
						end
					end
					readyPlayers[tableFolder][player] = nil
					return
				else
					return
				end
			end
			print("ready")
			print("same table")

			local seated = false
			for _, part in tableFolder:GetDescendants() do
				if part:IsA("Seat") and part.Occupant then
					if game.Players:GetPlayerFromCharacter(part.Occupant.Parent) == player then
						seated = true
						break
					end
				end
			end

			if not seated then return end
			print("seated")

			readyPlayers[tableFolder][player] = true

			local seatedCount = 0
			local readyCount = 0
			for _, part in tableFolder:GetDescendants() do
				if part:IsA("Seat") and part.Occupant then
					seatedCount += 1
					local p = game.Players:GetPlayerFromCharacter(part.Occupant.Parent)
					if p and readyPlayers[tableFolder][p] then
						readyCount += 1
						local char = part.Occupant.Parent
						if char then
							local humanoid = char:FindFirstChild("Humanoid")
							if humanoid then
								humanoid.WalkSpeed = 0
								humanoid.JumpHeight = 0
							end
						end
					end
				end
			end

			if readyCount == seatedCount and seatedCount >= 2 then
				readyPlayers[tableFolder] = {}
				task.spawn(function()
					local result = startTableGame(tableFolder)
					if result then
						local winners = type(result) == "table" and result or {result}

						for _, winner in winners do
							seatedCount = 0
							readyCount = 0

							local char = winner.Character
							if char then
								local humanoid = char:FindFirstChild("Humanoid")
								if humanoid then
									humanoid.WalkSpeed = 16
									humanoid.JumpHeight = 7.2
								end
							end

							local leaderstats = winner:FindFirstChild("leaderstats")
							if leaderstats then
								local wins = leaderstats:FindFirstChild("Wins")
								local money = leaderstats:FindFirstChild("Money")
								local streak = leaderstats:FindFirstChild("Streak")
								local winGamepass = winner:FindFirstChild("WinGamepass")
								local streakGamepass = winner:FindFirstChild("StreakGamepass")
								local moneyGamepass = winner:FindFirstChild("MoneyGamepass")
								local vipGamepass = winner:FindFirstChild("VIPGamepass")
								local C_Wins = winner:FindFirstChild("C_Wins") -------- REMOVE WHEN DAILY IS CHANGED
								local C_Spent = winner:FindFirstChild("C_Spent") ---------- REMOVE WHEN DAILY IS CHANGED

								if wins and money and streak and winGamepass and streakGamepass and moneyGamepass and vipGamepass then
									eventHandler:FireClient(winner, "Win")
									wins.Value += winGamepass.Value and 2 or 1
									streak.Value += streakGamepass.Value and 2 or 1

									if moneyGamepass.Value and vipGamepass.Value then
										money.Value += 300
									elseif moneyGamepass.Value then
										money.Value += 200
									elseif vipGamepass.Value then
										money.Value += 150
									else
										money.Value += 100
									end

									local char = winner.Character
									if char then
										local humanoid = char:FindFirstChild("Humanoid")
										if humanoid then
											humanoid.Sit = false
											humanoid.WalkSpeed = 16
											humanoid.JumpHeight = 7.2
										end
									end
									
									if C_Wins and C_Spent then
										C_Wins.Value += winGamepass.Value and 2 or 1
										dailyEvent:FireClient(winner, C_Wins.Value)
									end
								end
							end
						end
					end
				end)
			end
		end)

		local function updateBillboard()
			local totalOccupants = 0
			local amountOfChairs = 0

			for _, part in tableFolder:GetDescendants() do
				if part:IsA("Seat") then
					amountOfChairs += 1
					if part.Occupant ~= nil then
						totalOccupants += 1
					end
				end
			end

			local mainTable = tableFolder:FindFirstChild("Table")
			if mainTable then
				local main = mainTable:FindFirstChild("Main")
				if main then
					local billboard = main:FindFirstChild("BillboardGui")
					if billboard then
						local label = billboard:FindFirstChild("TextLabel")
						if label then
							label.Text = totalOccupants .. "/" .. amountOfChairs .. " Players"
						end
					end
				end
			end
		end

		for _, part in tableFolder:GetDescendants() do
			if part:IsA("Seat") then
				part:GetPropertyChangedSignal("Occupant"):Connect(function()
					updateBillboard()

					local seatParent = part.Parent

					if part.Occupant then
						local player = players:GetPlayerFromCharacter(part.Occupant.Parent)
						if player then
							local equipped = player:FindFirstChild("Equipped")
							if equipped and equipped.Value ~= "Nil" and equipped.Value ~= "" then
								local skin = chairFolderRep:FindFirstChild(equipped.Value)
								if skin then
									for _, child in seatParent:GetChildren() do
										if not child:IsA("Seat") then
											child.Transparency = 1
										end
									end
									local clone = skin:Clone()
									clone:PivotTo(seatParent:GetPivot())
									for _, child in clone:GetChildren() do
										if not child:IsA("Seat") then
											child.Name = "SkinClone"
											child.Parent = seatParent
										end
									end
									clone:Destroy()
								end
							end
						end
					else
						for _, child in seatParent:GetChildren() do
							if child.Name == "SkinClone" then
								child:Destroy()
							elseif not child:IsA("Seat") then
								child.Transparency = 0
							end
						end
					end
				end)
			end
		end

		object.Triggered:Connect(function(player)
			for _, part in tableFolder:GetDescendants() do
				if part:IsA("Seat") and part.Occupant == nil then
					local char = player.Character
					if char then
						local humanoid = char:FindFirstChild("Humanoid")
						part:Sit(humanoid)
						break
					end
				end
			end
		end)
	end
end

game.Players.PlayerRemoving:Connect(function(player)
	for _, object in tables:GetDescendants() do
		if object:IsA("Seat") and object.Occupant then
			local seatedPlayer = players:GetPlayerFromCharacter(object.Occupant.Parent)
			if seatedPlayer == player then
				local seatParent = object.Parent
				for _, child in seatParent:GetChildren() do
					if child.Name == "SkinClone" then
						child:Destroy()
					elseif not child:IsA("Seat") then
						child.Transparency = 0
					end
				end
			end
		end
	end
end)
