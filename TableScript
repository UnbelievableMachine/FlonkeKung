local readyPlayers = {}

local function eliminatePlayer(activePlayers, player, tableFolder, correctWord, i)
	if player then
		local leaderstats = player:FindFirstChild("leaderstats")
		if leaderstats then
			local streak = leaderstats:FindFirstChild("Streak")
			if streak then
				streak.Value = 0
			end
		end

		local char = player.Character
		if char then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			local humanoid = char:FindFirstChild("Humanoid")
			if humanoid and hrp then
				local seatBeingUsed = nil
				local originalSeatParent = nil
				local originalSeatCFrame = nil

				if tableFolder then
					for _, part in tableFolder:GetDescendants() do
						if part:IsA("Seat") and part.Occupant and part.Occupant.Parent == char then
							seatBeingUsed = part
							originalSeatParent = part.Parent
							originalSeatCFrame = part.CFrame
							break
						end
					end
				end

				humanoid.Sit = false

				local timeout = 0
				while humanoid.Sit and timeout < 20 do
					task.wait(0.05)
					timeout += 1
				end

				if seatBeingUsed and originalSeatCFrame then
					seatBeingUsed.CFrame = originalSeatCFrame
					seatBeingUsed.CanCollide = true
				end

				task.wait(0.2)

				hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
				task.wait(0.1)

				hrp.CFrame = spawnLoc.CFrame + Vector3.new(0, 5, 0)

				humanoid.JumpHeight = 7.2
				humanoid.WalkSpeed = 16

				if seatBeingUsed and originalSeatParent then
					task.wait(0.1)
					seatBeingUsed.CFrame = originalSeatCFrame
				end
			end
		end

		for _, plr in activePlayers do
			if plr ~= player then
				eventHandler:FireClient(plr, "Eliminated", player)
			elseif plr == player then
				eventHandler:FireClient(plr, "Wrong", player, correctWord, i)
			end
		end
	end
end

local function getAnswer(player, activePlayers, nmbr, answerTable, tableFolder, timerTaskRef)
	local answered = false
	local answer = nil

	if timerTaskRef.task then task.cancel(timerTaskRef.task) end
	timerTaskRef.task = task.spawn(function()
		local secs = 0
		for _, plr in activePlayers do
			eventHandler:FireClient(plr, "Time", 8, nmbr)
		end
		while not answered and secs < 8 do
			task.wait(1)
			secs += 1
			for _, plr in activePlayers do
				eventHandler:FireClient(plr, "Time", 8 - secs, nmbr)
			end
		end
	end)

	local correctAnswer = answerTable[nmbr]
	local ran = math.random(1, 10)
	local ranCategory = moduleScript.Options[categories[ran]]
	local randomQuestions = {}
	local usedWords = {}

	while #randomQuestions < 4 do
		local ran = math.random(1, 10)
		local word = ranCategory[ran]
		if not usedWords[word] then
			usedWords[word] = true
			table.insert(randomQuestions, word)
		end
	end

	if not usedWords[correctAnswer] then
		local replaceIndex = math.random(1, 4)
		randomQuestions[replaceIndex] = correctAnswer
	end

	local inserted = false
	if not usedWords[nmbr] and correctAnswer ~= tostring(nmbr) then
		while not inserted do
			local replaceIndex = math.random(1, 4)
			local picked = randomQuestions[replaceIndex]
			if picked ~= correctAnswer then
				randomQuestions[replaceIndex] = nmbr
				inserted = true
			end
		end
	end

	eventHandler:FireClient(player, "Question", nmbr, randomQuestions)

	local conn
	conn = eventHandler.OnServerEvent:Connect(function(plr, arg, arg2)
		if plr ~= player then return end
		if answered then return end
		if arg ~= "Question" then return end
		answered = true
		answer = arg2
		conn:Disconnect()
	end)

	local elapsed = 0
	while not answered and elapsed < 10 do
		task.wait(0.1)
		elapsed += 0.1
	end

	for _, plr in activePlayers do
		eventHandler:FireClient(plr, "Time", 0, nmbr)
	end
	eventHandler:FireClient(player, "Hide")

	if not answered then
		eliminatePlayer(activePlayers, player, tableFolder)
	end

	return answer
end

local function chooseOption(player, activePlayers, answerTable)
	local answered = false
	local answer = nil
	local number = nil

	local occupiedNmbrs = {}
	for i, num in answerTable do
		if tostring(i) ~= num then
			table.insert(occupiedNmbrs, i)
		end
	end

	eventHandler:FireClient(player, "Option", occupiedNmbrs)

	local conn
	conn = eventHandler.OnServerEvent:Connect(function(plr, arg, nmr, word)
		if plr ~= player then return end
		if answered then return end
		if arg ~= "Choose" then return end
		answered = true
		answer = word
		number = nmr
	end)

	local elapsed = 0
	while not answered and elapsed < 20 do
		task.wait(1)
		elapsed += 1
		for _, child in activePlayers do
			eventHandler:FireClient(child, "Time", 20 - elapsed, "Choose", player)
		end
	end

	if not answered then
		eventHandler:FireClient(player, "Hide")
		local random = math.random(1, 10)
		local randomCat = moduleScript.Options[categories[random]]
		if randomCat then
			local randomWord = math.random(1, 10)
			answer = randomCat[randomWord]
		end
	end

	for _, plr in activePlayers do
		eventHandler:FireClient(plr, "Hide")
	end

	print(answer)
	conn:Disconnect()
	return answer, number
end

local function startTableGame(tableFolder)
	local activePlayers = {}
	local playerBoosts = {}
	local timerTaskRef = { task = nil }

	for _, part in tableFolder:GetDescendants() do
		if part:IsA("Seat") then
			if part.Occupant then
				local player = players:GetPlayerFromCharacter(part.Occupant.Parent)
				if player then
					table.insert(activePlayers, player)
					eventHandler:FireClient(player, "Start")
				end
			end
		end
	end

	if #activePlayers < 2 then return end

	local answerTable = {}
	for i = 1, 10 do
		answerTable[i] = tostring(i)
	end

	for _, plr in activePlayers do
		local equipped = plr:FindFirstChild("Equipped")
		if equipped then
			local boost = chairBoosts.Boosts[equipped.Value]
			if boost then
				playerBoosts[plr] = boost
			end
		end
	end

	local chooserCount = 0

	task.wait(11.5)

	local roundOffset = 0

	while #activePlayers > 1 do
		for i = 1, 10 do
			if #activePlayers == 1 then return activePlayers[1] end

			local player = activePlayers[(i - 1 + roundOffset) % #activePlayers + 1]
			
			for _, plr in activePlayers do
				eventHandler:FireClient(plr, "FocusPlayer", player.Name)
			end

			local answer = getAnswer(player, activePlayers, i, answerTable, tableFolder, timerTaskRef)

			if answer == nil or answer ~= answerTable[i] then
				eliminatePlayer(activePlayers, player, tableFolder, answerTable[i], i)
				table.remove(activePlayers, table.find(activePlayers, player))

			elseif answer == answerTable[i] then
				local leaderstats = player:FindFirstChild("leaderstats")
				if leaderstats then
					local money = leaderstats:FindFirstChild("Money")
					local moneyGamepass = player:FindFirstChild("MoneyGamepass")
					local vipGamepass = player:FindFirstChild("VIPGamepass")
					if money and moneyGamepass and vipGamepass then
						local moneyGain = 0
						if moneyGamepass.Value and vipGamepass.Value then
							moneyGain = 13
						elseif moneyGamepass.Value then
							moneyGain = 10
						elseif vipGamepass.Value then
							moneyGain = 8
						else
							moneyGain = 5
						end

						local boost = playerBoosts[player] or 1
						moneyGain = math.floor((moneyGain * boost) * 10) / 10
						money.Value += moneyGain

						eventHandler:FireClient(player, "Correct", moneyGain)
					end
				end
			end
		end

		roundOffset += 1
		
		local playerChooser = activePlayers[chooserCount % #activePlayers + 1]
		chooserCount += 1

		if #activePlayers == 1 then
			return activePlayers[1]
		end

		for _, plr in activePlayers do
			eventHandler:FireClient(plr, "FocusPlayer", playerChooser.Name)
		end

		local availableNumbers = {}
		for i, num in answerTable do
			if tostring(i) == num then
				table.insert(availableNumbers, i)
			end
		end

		if #availableNumbers == 0 then
			return activePlayers
		end

		local word, nmbr = chooseOption(playerChooser, activePlayers, answerTable)

		if nmbr == nil then
			for i, num in answerTable do
				if tostring(i) == num then
					nmbr = i
					break
				end
			end
		end

		answerTable[nmbr] = word

		for _, child in activePlayers do
			eventHandler:FireClient(child, "NumToWord", word, nmbr)
			print("fired")
		end
	end

	return activePlayers[1]
end

